    {
      "name": "GitHub",
      "url": "https://github.com/maschina-labs"
    },
    {
      "name": "X",
      "url": "https://x.com/MaschinaAI"
    },
    {
      "name": "Discord",
      "url": "https://discord.gg/maschina"
    }
  ],
  "tabs": [
    { "name": "Guides", "url": "guides" },
    { "name": "Platform", "url": "platform" },
    { "name": "SDKs", "url": "sdks" },
