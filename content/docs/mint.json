{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Maschina",
  "favicon": "/brand/favicon.svg",
  "appearance": "dark",
  "modeToggle": {
    "default": "dark",
    "isHidden": true
  },
  "colors": {
    "primary": "#B83232",
    "light": "#CC3333",
    "dark": "#8C1F1F",
    "background": {
