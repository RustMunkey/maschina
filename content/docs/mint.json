    },
    {
      "group": "Platform",
      "pages": [
        "platform/overview",
        "platform/network",
        "platform/nodes",
        "platform/marketplace",
        "platform/economics",
        "platform/roadmap"
      ]
    },
    {
      "group": "SDKs",
      "pages": ["sdks/typescript", "sdks/python", "sdks/rust", "sdks/rest"]
    },
    {
      "group": "API Reference",
      "pages": [
        "api-reference/authentication",
        "api-reference/agents",
        "api-reference/runs",
        "api-reference/keys",
        "api-reference/usage",
        "api-reference/webhooks",
        "api-reference/search",
        "api-reference/realtime",
        "api-reference/compliance"
      ]
