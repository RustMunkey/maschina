{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@maschina/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": "..",
    "paths": {
      "@maschina/*": ["packages/*/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.spec.ts"],
  "exclude": ["node_modules", "dist"]
}
