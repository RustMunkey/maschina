    "tests": "turbo test --filter=@maschina/tests",
    "test:e2e": "vitest run --root tests/e2e",
    "test:integration": "vitest run --root tests/integration",
    "test:load": "echo 'Load tests — tooling TBD (k6 / locust)'",

    "db": "turbo db:studio --filter=@maschina/db",
    "db:push": "turbo db:push --filter=@maschina/db",
    "db:migrate": "turbo db:migrate --filter=@maschina/db",
    "db:generate": "turbo db:generate --filter=@maschina/db",

    "kill:api": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "kill:gateway": "lsof -ti:8080 | xargs kill -9 2>/dev/null || true",
    "kill:realtime": "lsof -ti:4000 | xargs kill -9 2>/dev/null || true",
    "kill:runtime": "lsof -ti:8001 | xargs kill -9 2>/dev/null || true",
    "kill:daemon": "lsof -ti:9090 | xargs kill -9 2>/dev/null || true",
    "kill:all": "pnpm kill:api && pnpm kill:gateway && pnpm kill:realtime && pnpm kill:runtime && pnpm kill:daemon",

    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:dev": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:ps": "docker compose -f docker/docker-compose.yml ps",
    "docker:reset": "docker compose -f docker/docker-compose.yml down -v",

    "prepare": "husky",
    "hooks:install": "git config core.hooksPath .github/hooks",

    "ci": "pnpm check && pnpm build:packages && pnpm test",
    "ci:ts": "pnpm check && pnpm build:packages && turbo test --filter='!@maschina/daemon' --filter='!@maschina/cli' --filter='!@maschina/code' --filter='!@maschina/rust'",
    "ci:rust": "pnpm check:rust && pnpm build:rust && pnpm test:rust",
    "ci:python": "pytest tests packages/runtime packages/agents packages/ml packages/risk packages/sdk/python services/worker services/runtime",
    "ci:e2e": "turbo test --filter=@maschina/tests",
    "ci:integration": "vitest run --root tests/integration"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "semantic-release": "^24",
    "@semantic-release/changelog": "^6",
    "@semantic-release/git": "^10",
    "@semantic-release/github": "^10",
    "conventional-changelog-conventionalcommits": "^8",
    "turbo": "latest",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.3"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.39.3"
    },
    "onlyBuiltDependencies": ["@biomejs/biome", "better-sqlite3", "esbuild"],
    "peerDependencyRules": {
      "allowedVersions": {
        "md-to-react-email>react": "19"
      }
    }
  }
}
