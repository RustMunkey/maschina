{
  "name": "maschina",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "biome check .",
    "typecheck": "pnpm --filter @maschina/api run build",
    "check": "biome check .",
    "format": "biome format --write .",
    "clean": "turbo clean",

    "check:rust": "cargo clippy --workspace",
    "test:rust": "cargo test --workspace",
    "build:rust": "cargo build --workspace --release",

    "cargo:build": "cargo build --workspace",
    "cargo:build:release": "cargo build --workspace --release",
    "cargo:test": "cargo test --workspace",
    "cargo:check": "cargo check --workspace",
    "cargo:clippy": "cargo clippy --workspace",
    "cargo:fmt": "cargo fmt --all",
    "cargo:clean": "cargo clean",
    "cargo:run:daemon": "cargo run -p maschina-daemon",
    "cargo:run:gateway": "cargo run -p maschina-gateway",
    "cargo:run:realtime": "cargo run -p maschina-realtime",
    "cargo:run:cli": "cargo run -p maschina-cli",
    "cargo:run:code": "cargo run -p maschina-code",

    "pytest": "pytest packages/runtime packages/agents packages/ml packages/model packages/risk packages/sdk/python services/worker services/runtime",
    "pytest:runtime": "pytest packages/runtime",
    "pytest:runtime-service": "pytest services/runtime",
