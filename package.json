    "desktop": "turbo dev --filter=@maschina/desktop",
    "mobile": "turbo dev --filter=@maschina/mobile",
    "api": "turbo dev --filter=@maschina/api",
    "daemon": "cd services/daemon && cargo run -p maschina-daemon",
    "gateway": "cd services/gateway && cargo run -p maschina-gateway",
    "realtime": "cd services/realtime && cargo run -p maschina-realtime",
    "runtime": "cd services/runtime && .venv/bin/uvicorn src.main:app --port 8001 --reload",
    "worker": "cd services/worker && .venv/bin/python -m worker.main",
    "analytics": "turbo dev --filter=@maschina/analytics",
    "email": "turbo dev --filter=@maschina/email",
    "cli": "turbo dev --filter=@maschina/cli",
