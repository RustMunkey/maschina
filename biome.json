{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignore": ["**/routeTree.gen.ts", "**/routeTree.gen.js", "apps/**"]
  },
  "overrides": [
    {
      "include": ["packages/ui/src/components/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useFocusableInteractive": "off",
            "useSemanticElements": "off"
          },
          "security": { "noDangerouslySetInnerHtml": "off" },
          "suspicious": { "noArrayIndexKey": "off" },
          "correctness": { "useExhaustiveDependencies": "off" }
        }
      }
    },
    {
      "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "services/*/src/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" }
        }
      }
    }
  ],
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
