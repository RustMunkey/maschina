[Unit]
Description=Maschina auto-update
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/bin/bash %h/Desktop/maschina/scripts/update.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=maschina-update

[Install]
WantedBy=default.target
