{
  "id": null,
  "uid": "maschina-infra",
  "title": "Maschina Infrastructure",
  "tags": ["maschina"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Exporters Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "up",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory Usage %",
      "type": "timeseries",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Disk Usage %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)",
          "legendFormat": "Disk /",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "pg_stat_activity_count{state=\"idle\"}",
          "legendFormat": "idle",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Redis Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Redis Commands/sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "cmd/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "rx {{ device }}",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "tx {{ device }}",
          "refId": "B"
        }
      ]
    }
  ]
}
