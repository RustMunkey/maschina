# ─── NATS ─────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# ─── Server ───────────────────────────────────────────────────────────────────
REALTIME_PORT=4000
NODE_ENV=development

# ─── Observability ────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
