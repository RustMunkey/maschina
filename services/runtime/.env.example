# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ───────────────────────────────────────────────────────────────────
RUNTIME_PORT=8001
NODE_ENV=development

# ─── Execution limits ─────────────────────────────────────────────────────────
# Default timeout for a single agent run (seconds)
DEFAULT_TIMEOUT_SECS=300
# Max tokens the runtime will ever allow per run (hard ceiling)
MAX_OUTPUT_TOKENS=16384
