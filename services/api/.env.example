# ─── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (dev):
DATABASE_URL=file:./dev.db
# PostgreSQL (staging/prod):
# DATABASE_URL=postgresql://maschina:maschina@localhost:5432/maschina

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── NATS ─────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:1420

# ─── Meilisearch ──────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterkey-change-in-production

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                  # only needed for Qdrant Cloud / production

# ─── Temporal ─────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233

# ─── Email (Resend — configure once domain is set up) ─────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=Maschina <noreply@yourdomain.com>

# ─── App URL (used in email links) ───────────────────────────────────────────
APP_URL=http://localhost:5173

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=debug
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
