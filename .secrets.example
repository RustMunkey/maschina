# Copy this to .secrets (gitignored) and fill in values for local act testing.
# Run: cp .secrets.example .secrets

# Required for deploy.yml
FLY_API_TOKEN=your_fly_deploy_token_here

# Required for deploy.yml image push (acts as GITHUB_TOKEN in act)
GITHUB_TOKEN=your_github_pat_here

# Required for ts-test job (matches CI env vars — use local or real values)
# DATABASE_URL, REDIS_URL, NATS_URL, JWT_SECRET are set inline in ci.yml
# and don't need to be in .secrets for CI jobs.
